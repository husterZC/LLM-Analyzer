flowchart TD
  title["layers.0 MiMo V2 attention detail"]
  x["Layer input\nhidden=4096"] --> norm["Input RMSNorm"]
  norm --> qproj["q_proj\nhidden -> Q=12288"]
  norm --> kproj["k_proj\nhidden -> K=768"]
  norm --> vproj["v_proj\nhidden -> V=512"]
  qproj --> q["Q reshape\n[B,T,64,192]"]
  kproj --> k["K reshape\n[B,T,4,192]"]
  vproj --> v["V reshape\n[B,T,4,128]"]
  v --> vscale["value scale\nalpha=0.707"]
  q --> qrope["partial RoPE on first 64 dims\ntheta=5000000"]
  k --> krope["partial RoPE on first 64 dims"]
  krope --> kcache["KV cache update"]
  vscale --> vcache["KV cache update"]
  kcache --> repeatk["repeat K heads\nkv groups=16"]
  vcache --> repeatv["repeat V heads\nkv groups=16"]
  qrope --> score["scores = Q K^T / sqrt(192)"]
  repeatk --> score
  score --> mask["causal mask"]
  mask --> softmax["softmax over key positions"]
  softmax --> pv["context = P V"]
  repeatv --> pv
  pv --> merge["merge heads\n[B,T,8192]"]
  merge --> out["o_proj\n8192 -> hidden"]
  out --> residual["residual add"]
