flowchart TD
  title["layers.1 MiMo V2 attention detail"]
  x["Layer input\nhidden=4096"] --> norm["Input RMSNorm"]
  norm --> qkv["fused qkv_proj\nhidden -> q+k+v = 14848\nlayout=fused_qkv"]
  qkv --> split["split Q/K/V\nQ=12288 K=1536 V=1024"]
  split --> q["Q reshape\n[B,T,64,192]"]
  split --> k["K reshape\n[B,T,8,192]"]
  split --> v["V reshape\n[B,T,8,128]"]
  v --> vscale["value scale\nalpha=0.707"]
  q --> qrope["partial RoPE on first 64 dims\ntheta=10000"]
  k --> krope["partial RoPE on first 64 dims"]
  krope --> kcache["sliding-window ring cache update"]
  vscale --> vcache["sliding-window ring cache update"]
  kcache --> repeatk["repeat K heads\nkv groups=8"]
  vcache --> repeatv["repeat V heads\nkv groups=8"]
  qrope --> score["scores = Q K^T / sqrt(192)"]
  repeatk --> score
  score --> mask["causal + sliding-window=128 mask"]
  mask --> sink["attention sink bias\nper-head learned sink logit"]
  sink --> softmax["softmax over key positions"]
  softmax --> pv["context = P V"]
  repeatv --> pv
  pv --> merge["merge heads\n[B,T,8192]"]
  merge --> out["o_proj\n8192 -> hidden"]
  out --> residual["residual add"]
